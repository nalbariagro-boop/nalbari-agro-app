generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  STAFF
}

model User {
  id           Int      @id @default(dbgenerated("generated by default as identity"))
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  timingReports TimingReport[]

  @@map("users")
}

model TimingReport {
  id         Int      @id @default(dbgenerated("generated by default as identity"))
  reportDate DateTime @map("report_date") @db.Date
  serial     Int
  partyId    Int?     @map("party_id")
  partyRef   Party?   @relation(fields: [partyId], references: [id])
  party      String
  lorry      String?
  challan    String?
  challanWeight Decimal? @map("challan_weight") @db.Decimal(12, 2)
  wb         Decimal? @db.Decimal(12, 2)
  excess     Decimal? @db.Decimal(12, 2)
  short      Decimal? @db.Decimal(12, 2)
  moisture   Decimal? @db.Decimal(6, 2)
  acceptQty  Decimal? @map("accept_qty") @db.Decimal(12, 2)
  fine       Decimal? @db.Decimal(6, 2)
  softBanji  Decimal? @map("soft_banji") @db.Decimal(6, 2)
  coarse     Decimal? @db.Decimal(6, 2)
  remarks    String?
  rate       Decimal? @db.Decimal(12, 2)
  amount     Decimal? @db.Decimal(12, 2)
  arrival    String?
  createdById Int?     @map("created_by_id")
  createdBy   User?    @relation(fields: [createdById], references: [id])

  @@index([reportDate])
  @@index([createdById])
  @@index([partyId])
  @@map("timing_reports")
}

model Party {
  id    Int    @id @default(dbgenerated("generated by default as identity"))
  name  String
  phone String @default("")
  area  String @default("")
  bank  String @default("")
  accountNumber String @default("") @map("account_number")
  notes String @default("")
  timingReports TimingReport[]

  @@map("parties")
}

model LedgerEntry {
  id          Int      @id @default(dbgenerated("generated by default as identity"))
  txnDate     DateTime @map("txn_date") @db.Date
  partyId     Int?     @map("party_id")
  party       String
  description String
  txnType     String   @map("txn_type")
  debit       Decimal  @default(0) @db.Decimal(12, 2)
  credit      Decimal  @default(0) @db.Decimal(12, 2)

  @@index([txnDate])
  @@index([party])
  @@index([partyId])
  @@map("ledger")
}
